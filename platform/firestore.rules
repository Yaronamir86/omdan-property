rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    match /cases/{caseId} {
      allow read: if isAuth() && resource.data.createdBy == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.createdBy == request.auth.uid;
    }

    match /propertyCases/{caseId} {
      allow read, write: if isAuth();
    }

    match /billing/{uid} {
      allow read: if isAuth() && isOwner(uid);
      allow create: if isAuth() && isOwner(uid);
      allow update: if isAuth() && isOwner(uid);
    }

    match /checkoutSessions/{sessionId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth();
    }

    match /payments/{paymentId} {
      allow read: if isAuth();
    }
  }
}
